# Configuración del agente local de Mission Control.
# Copia este fichero a .env.local y rellena los valores.

# URL del backend de Mission Control (Vercel).
# Ejemplo: https://missioncontrol-abc123.vercel.app
MC_API_URL=

# Secreto compartido con el backend.
# Debe coincidir con la variable MC_API_KEY configurada en Vercel.
MC_API_KEY=

# Identificador de esta máquina. Usa "casa" o "trabajo" según corresponda.
MACHINE_ID=casa

# Carpeta a escanear. Por defecto ~/Projects.
# PROJECTS_DIR=/Users/telmo/Projects
